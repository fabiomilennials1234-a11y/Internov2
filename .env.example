# ───────── Banco · Supabase (Postgres) ─────────
# Runtime usa o POOLER (pgBouncer, porta 6543). Migrations usam a conexão DIRETA (5432).
DATABASE_URL="postgresql://postgres.xxxx:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Local (docker-compose) — descomente p/ rodar offline:
# DATABASE_URL="postgresql://interno:interno@localhost:5432/interno?schema=public"
# DIRECT_URL="postgresql://interno:interno@localhost:5432/interno?schema=public"

# ───────── Redis (BullMQ + pub/sub websocket) ─────────
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ───────── Auth (JWT próprio + refresh) ─────────
JWT_ACCESS_SECRET="troque-isto-em-prod"
JWT_REFRESH_SECRET="troque-isto-tambem"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ───────── API ─────────
PORT="3000"
CORS_ORIGIN="http://localhost:5173"

# ───────── Supabase Storage (anexos — fase posterior) ─────────
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# ───────── Web (Vite) ─────────
VITE_API_URL="http://localhost:3000"
